# Copy to project.local.yaml (gitignored). Never commit real client data.

project:
  name: "My Local Business"
  domain: "example.com"
  origin: "https://example.com"
  locale: "en-US"
  market: "Your City, Your Country"

# Standalone test with bundled samples:
data_sources:
  gsc_glob: "data/samples/gsc_sample.csv"
  sf_glob: "data/samples/sf_sample.csv"

